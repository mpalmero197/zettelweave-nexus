{
  "manifest_version": 3,
  "name": "PendragonX Toolbox",
  "version": "1.18.0",
  "description": "PendragonX Toolbox",
  "permissions": ["storage", "activeTab", "sidePanel", "tabs", "alarms", "scripting", "contextMenus", "notifications", "webNavigation"],
  "host_permissions": [
    "https://sckglgjydlbztxjupbsk.supabase.co/*",
    "<all_urls>"
  ],
  "action": {
    "default_title": "Open PendragonX Toolbox",
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://pendragonx.com/*",
        "https://*.pendragonx.com/*",
        "https://*.lovable.app/*"
      ],
      "js": ["vault-bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["recorder.js", "runner.js", "agent.js", "vault-bridge.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}
