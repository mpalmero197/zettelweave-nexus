{
  "manifest_version": 3,
  "name": "PendragonX Quick Notes",
  "version": "1.4.0",
  "description": "Full PendragonX assistant in Chrome's side panel — chat with ALICE, capture notes, run focus sessions, track habits, and share browser context.",
  "permissions": ["storage", "activeTab", "sidePanel", "tabs", "alarms"],
  "host_permissions": ["https://sckglgjydlbztxjupbsk.supabase.co/*"],
  "action": {
    "default_title": "Open PendragonX",
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}
