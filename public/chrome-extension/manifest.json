{
  "manifest_version": 3,
  "name": "PendragonX Toolbox",
  "version": "1.7.1",
  "description": "PendragonX Toolbox",
  "permissions": ["storage", "activeTab", "sidePanel", "tabs", "alarms", "scripting"],
  "host_permissions": [
    "https://sckglgjydlbztxjupbsk.supabase.co/*",
    "<all_urls>"
  ],
  "action": {
    "default_title": "Open PendragonX Toolbox",
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}
