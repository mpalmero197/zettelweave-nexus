# Long-cache hashed Vite build assets
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Static icons / favicons (rotate occasionally)
/icon-192x192.png
  Cache-Control: public, max-age=2592000
/icon-512x512.png
  Cache-Control: public, max-age=2592000
/favicon.png
  Cache-Control: public, max-age=2592000
/favicon.ico
  Cache-Control: public, max-age=2592000

# Service worker must always revalidate
/push-sw.js
  Cache-Control: public, max-age=0, must-revalidate

# PWA manifest
/manifest.webmanifest
  Cache-Control: public, max-age=86400

# llms.txt / robots / sitemap — daily
/llms.txt
  Cache-Control: public, max-age=86400
/llms-full.txt
  Cache-Control: public, max-age=86400
/robots.txt
  Cache-Control: public, max-age=86400
/sitemap.xml
  Cache-Control: public, max-age=86400

# HTML shell — always revalidate so deploys roll out immediately
/
  Cache-Control: public, max-age=0, must-revalidate
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
